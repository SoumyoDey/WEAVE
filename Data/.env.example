# ── Flask API environment variables  (copy to .env and fill in values) ───────
# .env is gitignored; .env.example is committed as a template.

# ── PostgreSQL connection ──────────────────────────────────────────────────────
DB_NAME=weave_weather
DB_USER=your_pg_username
DB_PASSWORD=your_pg_password
DB_HOST=localhost
DB_PORT=5432

# Connection pool size
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── Flask server ───────────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=true

# ── CORS allowed origin (React dev server) ────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
